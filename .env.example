# This file is a placeholder for environment variables required to run this project.                                       │
 
# Example of what future variables might look like:                                                                        │
# NEXT_PUBLIC_API_KEY=your_api_key_here                                                                                    │
# DATABASE_URL=your_database_url_here                                                                                      │
# SECRET_KEY=your_secret_key_here                                                                                          │

# Password for protected pages/routes                                                                                      │
PAGE_ACCESS_PASSWORD=password

NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1

# Security
FORCE_HTTPS=true

# Performance
NEXT_CACHE_HANDLER=default

# Resend API Configuration for the Contact Page
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here
